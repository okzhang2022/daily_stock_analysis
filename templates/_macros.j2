{% if snapshot.get('close') %}{% set parts = parts + [labels.close_label ~ ' ' ~ snapshot.get('close')] %}{% endif %}
{% if snapshot.get('pct_chg') %}{% set parts = parts + [labels.change_pct_label ~ ' ' ~ snapshot.get('pct_chg')] %}{% endif %}
